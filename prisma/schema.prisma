generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id          Int       @id @default(autoincrement())
  userid      String    @unique
  password    String
  name        String
  email       String?   @unique
  lastLoginAt DateTime?

  letters                 Letter[]
  letterDraft             LetterDraft?
  teacherLetters          TeacherLetter[]
  teacherLetterDeliveries TeacherLetterDelivery[]
}

model Letter {
  id                    Int       @id @default(autoincrement())
  type                  String    @default("text")
  content               String?
  videoUrl              String?
  imageUrl              String?
  signatureData         String?
  deliveryEmail         String?
  sentToEmail           String?
  emailSubject          String?
  emailTheme            String    @default("dark")
  recipientEmail        String?
  recipientName         String?
  callReplyVideoUrl     String?
  callCompositeVideoUrl String?
  callReplyEmail        String?
  callReplySentAt       DateTime?
  favorite              Boolean   @default(false)
  openDate              DateTime
  createdAt             DateTime  @default(now())
  sentAt                DateTime?

  author   Member @relation(fields: [authorId], references: [id])
  authorId Int
}

model LetterDraft {
  id             Int       @id @default(autoincrement())
  type           String    @default("text")
  content        String?
  videoUrl       String?
  imageUrl       String?
  signatureData  String?
  deliveryEmail  String?
  emailSubject   String?
  emailTheme     String    @default("dark")
  recipientEmail String?
  recipientName  String?
  toOther        Boolean   @default(false)
  openDate       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  author   Member @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId Int    @unique
}

model TeacherLetter {
  id          Int      @id @default(autoincrement())
  title       String?
  teacherName String
  content     String
  createdAt   DateTime @default(now())
  active      Boolean  @default(true)

  author     Member                  @relation(fields: [authorId], references: [id])
  authorId   Int
  deliveries TeacherLetterDelivery[]
}

model TeacherLetterDelivery {
  id              Int       @id @default(autoincrement())
  memberId        Int       @unique
  teacherLetterId Int
  createdAt       DateTime  @default(now())
  sentAt          DateTime?
  lastError       String?

  member        Member        @relation(fields: [memberId], references: [id])
  teacherLetter TeacherLetter @relation(fields: [teacherLetterId], references: [id])
}

model PublicLetter {
  id        Int      @id @default(autoincrement())
  nickname  String
  type      String   @default("text")
  content   String?
  imageUrl  String?
  pinHash   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  visible   Boolean  @default(true)
}

model SupportMessage {
  id        Int      @id @default(autoincrement())
  name      String?
  userid    String?
  email     String?
  content   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
